<mxfile host="app.diagrams.net" type="device">
  <diagram id="nas-sync-wf-1" name="NAS Sync Workflow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="legend" value="LEGEND&#10;■ green  = success / guarantee&#10;■ blue   = server  (Cluster B)&#10;■ orange = daily client (Cluster A)&#10;■ red    = failure → job action&#10;■ purple = weekly reconcile&#10;◆ yellow = decision" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="830" y="20" width="300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="init_hdr" value="① INITIAL BULK SYNC — one-time&#10;Deployment + SYNC_MODE=parallel · no time limit&#10;→ full parallel pull (walk whole tree)&#10;→ on COMPLETE: tear down, seed marker = completion time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="320" height="120" as="geometry" />
        </mxCell>

        <mxCell id="srv_hdr" value="② MANIFEST CRONJOB (Cluster B) ~01:00&#10;runs AHEAD of the daily client window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="srv_cand" value="touch CANDIDATE = scan-start time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="srv_dec" value="marker&#10;exists?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="110" y="335" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="srv_full" value="FIRST RUN&#10;write FULL_SYNC&#10;+ sentinel,&#10;publish + set marker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="20" y="455" width="150" height="95" as="geometry" />
        </mxCell>
        <mxCell id="srv_find" value="parallel find -newer marker&#10;(split by top-level folder)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="455" width="170" height="95" as="geometry" />
        </mxCell>
        <mxCell id="srv_assemble" value="assemble list + append&#10;# COMPLETE &lt;epoch&gt; &lt;count&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="585" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="srv_publish" value="ATOMIC publish:&#10;mv tmp → manifest.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="660" width="240" height="45" as="geometry" />
        </mxCell>
        <mxCell id="srv_marker" value="advance marker (mv CANDIDATE → marker)&#10;ONLY after publish — no lost changes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="80" y="725" width="240" height="55" as="geometry" />
        </mxCell>
        <mxCell id="srv_ready" value="manifest.txt READY&#10;served via nas-data module" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="805" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cl0" value="③ DAILY CRONJOB (Cluster A) ~03:00&#10;SYNC_MODE=incremental · backoffLimit 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="180" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cl1" value="pre-flight OK?&#10;(pwd / remote / mount)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="510" y="270" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cl_fetch" value="fetch manifest&#10;.sync-state/manifest.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="500" y="380" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="cl3" value="manifest present&#10;and has # COMPLETE&#10;sentinel?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="500" y="445" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="cl4" value="epoch &gt;&#10;last-consumed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="510" y="575" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cl5" value="FULL_SYNC&#10;signal?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="510" y="690" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cl6a" value="full pull&#10;(whole module)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="410" y="805" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cl6b" value="rsync --files-from&#10;only changed (~12K)&#10;NO tree walk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="600" y="805" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cl7" value="rsync exit&#10;0 or 24?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="510" y="910" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cl8" value="record last-consumed = epoch&#10;=== COMPLETE (success) ===&#10;(repeats next day)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="480" y="1030" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="A_pre" value="die → exit non-zero&#10;NO target change&#10;Job = Failed (ALERT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="830" y="270" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="A_sent" value="SKIP + ALERT&#10;manifest missing / incomplete&#10;exit non-zero · no change&#10;retry next cycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="830" y="447" width="300" height="85" as="geometry" />
        </mxCell>
        <mxCell id="A_stale" value="SKIP + ALERT (stale)&#10;manifest not refreshed by server&#10;exit non-zero · no change · retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="830" y="572" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="A_fail" value="sync FAILED&#10;last-consumed NOT advanced&#10;retry next run; changes re-appear in&#10;next manifest (conservative marker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="830" y="900" width="300" height="95" as="geometry" />
        </mxCell>

        <mxCell id="rec0" value="④ WEEKLY RECONCILE (Cluster A)&#10;SYNC_MODE=parallel · Sun 02:00" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1170" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rec1" value="full bilateral compare (parallel)&#10;NO --delete (additive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="410" y="1170" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rec2" value="self-heals ANY drift&#10;(files missed by failed daily runs)&#10;GUARANTEE: convergence ≤ 7 days" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="780" y="1170" width="340" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="seeds marker" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="init_hdr" target="srv_hdr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="fills target first" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="init_hdr" target="cl0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_hdr" target="srv_cand">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_cand" target="srv_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="no (first run)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_dec" target="srv_full">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_dec" target="srv_find">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_find" target="srv_assemble">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_assemble" target="srv_publish">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_publish" target="srv_marker">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_marker" target="srv_ready">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="srv_full" target="srv_ready">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="client reads latest COMPLETE manifest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="srv_ready" target="cl_fetch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl0" target="cl1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;" edge="1" parent="1" source="cl1" target="A_pre">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl1" target="cl_fetch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl_fetch" target="cl3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;" edge="1" parent="1" source="cl3" target="A_sent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl3" target="cl4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e19" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;" edge="1" parent="1" source="cl4" target="A_stale">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e20" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl4" target="cl5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e21" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl5" target="cl6a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e22" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl5" target="cl6b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl6a" target="cl7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl6b" target="cl7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e25" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;" edge="1" parent="1" source="cl7" target="A_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e26" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cl7" target="cl8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e27" value="healed ≤ 7 days" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="A_fail" target="rec2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="rec0" target="rec1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="rec1" target="rec2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
